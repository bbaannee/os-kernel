  12:src/MemoryAllocator.cpp ****         return -1;
  13:src/MemoryAllocator.cpp ****     }
  14:src/MemoryAllocator.cpp **** 
  15:src/MemoryAllocator.cpp ****     segmentHeader* curr = head;
