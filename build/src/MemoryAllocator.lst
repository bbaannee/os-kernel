  17:src/MemoryAllocator.cpp **** 
  18:src/MemoryAllocator.cpp **** 
  19:src/MemoryAllocator.cpp ****     while(curr) {
  20:src/MemoryAllocator.cpp ****         if(curr == newFree) {
  21:src/MemoryAllocator.cpp ****             return -1;
  22:src/MemoryAllocator.cpp ****         }
  23:src/MemoryAllocator.cpp ****         if(curr > newFree) break;
  24:src/MemoryAllocator.cpp **** 
  25:src/MemoryAllocator.cpp ****         prev = curr;
  26:src/MemoryAllocator.cpp ****         curr = curr->next;
  27:src/MemoryAllocator.cpp ****     }
  28:src/MemoryAllocator.cpp **** 
  29:src/MemoryAllocator.cpp ****     if(prev) {
  30:src/MemoryAllocator.cpp ****         newFree->next = prev->next;
  31:src/MemoryAllocator.cpp ****         prev->next = newFree;
  32:src/MemoryAllocator.cpp ****     } else {
  33:src/MemoryAllocator.cpp ****         newFree->next = head;
  34:src/MemoryAllocator.cpp ****         head = newFree;
  35:src/MemoryAllocator.cpp ****     }
